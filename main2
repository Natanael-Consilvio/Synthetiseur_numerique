static void Refresh_Effects_UI(void);

static void mode_switch_cb(lv_event_t *e) {
    lv_obj_t *sw = lv_event_get_target(e);
    g_effect_mode = lv_obj_has_state(sw, LV_STATE_CHECKED) ? MODE_PRO : MODE_EASY;
    Refresh_Effects_UI();
}

static void Refresh_Effects_UI(void) {
    if (!tab_eff) return;
    lv_obj_clean(tab_eff);

    lv_obj_t *row0 = lv_obj_create(tab_eff);
    lv_obj_set_size(row0, LV_PCT(100), 50);
    lv_obj_set_flex_flow(row0, LV_FLEX_FLOW_ROW);
    lv_obj_set_flex_align(row0, LV_FLEX_ALIGN_CENTER, LV_FLEX_ALIGN_CENTER, LV_FLEX_ALIGN_CENTER);
    lv_obj_set_style_pad_all(row0, 6, 0);
    lv_obj_set_style_border_width(row0, 0, 0);
    lv_obj_set_style_bg_opa(row0, LV_OPA_TRANSP, 0);

    lv_obj_t *lbl_m = lv_label_create(row0);
    lv_label_set_text(lbl_m, g_effect_mode == MODE_PRO ? "Mode PRO" : "Mode EASY");
    lv_obj_set_style_text_color(lbl_m,
        g_effect_mode == MODE_PRO ? lv_color_hex(0xff6600) : lv_color_hex(0x00cc88), 0);

    lv_obj_t *sw = lv_switch_create(row0);
    if (g_effect_mode == MODE_PRO) lv_obj_add_state(sw, LV_STATE_CHECKED);
    lv_obj_add_event_cb(sw, mode_switch_cb, LV_EVENT_VALUE_CHANGED, NULL);

    const char *labels_easy[] = {"Chaleur", "Profondeur", "Brillance"};
    const char *labels_pro[]  = {"Reverb",  "Delay",      "Chorus"};
    const char **labels = (g_effect_mode == MODE_EASY) ? labels_easy : labels_pro;

    for (int i = 0; i < 3; i++) {
        lv_obj_t *row = lv_obj_create(tab_eff);
        lv_obj_set_size(row, LV_PCT(100), 50);
        lv_obj_set_flex_flow(row, LV_FLEX_FLOW_ROW);
        lv_obj_set_flex_align(row, LV_FLEX_ALIGN_SPACE_BETWEEN,
                              LV_FLEX_ALIGN_CENTER, LV_FLEX_ALIGN_CENTER);
        lv_obj_set_style_pad_all(row, 6, 0);
        lv_obj_set_style_border_width(row, 0, 0);
        lv_obj_set_style_bg_opa(row, LV_OPA_TRANSP, 0);

        lv_obj_t *lbl = lv_label_create(row);
        lv_label_set_text(lbl, labels[i]);

        lv_obj_t *sl = lv_slider_create(row);
        lv_slider_set_range(sl, 0, 100);
        lv_slider_set_value(sl, g_eff_param[i], LV_ANIM_OFF);
        lv_obj_set_width(sl, 200);
        lv_obj_add_event_cb(sl, effect_param_cb, LV_EVENT_VALUE_CHANGED,
                            (void *)(uintptr_t)i);
    }
}

static void Create_Synth_UI(void) {
    lv_obj_t *scr = lv_scr_act();
    lv_obj_set_style_bg_color(scr, lv_color_hex(0x1a1a2e), 0);

    lv_obj_t *tv = lv_tabview_create(scr);
    lv_obj_set_size(tv, LV_PCT(100), LV_PCT(100));

    lv_obj_t *tab_timbre = lv_tabview_add_tab(tv, "Timbre");
    lv_obj_set_flex_flow(tab_timbre, LV_FLEX_FLOW_COLUMN);
    lv_obj_set_style_pad_row(tab_timbre, 6, 0);

    lbl_osc_sel = lv_label_create(tab_timbre);
    lv_label_set_text(lbl_osc_sel, "OSC actif : 1  (M1=Detune  M8=Volume)");
    lv_obj_set_style_text_color(lbl_osc_sel, lv_color_hex(0x00ff88), 0);

    const char *osc_names[] = {"OSC 1", "OSC 2", "OSC 3"};

    for (int i = 0; i < NUM_OSC; i++) {
        lv_obj_t *row = lv_obj_create(tab_timbre);
        lv_obj_set_size(row, LV_PCT(100), 55);
        lv_obj_set_flex_flow(row, LV_FLEX_FLOW_ROW);
        lv_obj_set_flex_align(row, LV_FLEX_ALIGN_SPACE_BETWEEN,
                              LV_FLEX_ALIGN_CENTER, LV_FLEX_ALIGN_CENTER);
        lv_obj_set_style_pad_all(row, 4, 0);
        lv_obj_set_style_border_width(row, 0, 0);
        lv_obj_set_style_bg_opa(row, LV_OPA_TRANSP, 0);

        lv_obj_t *lbl = lv_label_create(row);
        lv_label_set_text(lbl, osc_names[i]);

        lv_obj_t *dd = lv_dropdown_create(row);
        lv_dropdown_set_options(dd, "Sinus\nCarre\nScie");
        lv_dropdown_set_selected(dd, osc[i].wave_mode);
        lv_obj_set_width(dd, 110);
        lv_obj_add_event_cb(dd, osc_wave_cb, LV_EVENT_VALUE_CHANGED,
                            (void *)(uintptr_t)i);

        lv_obj_t *sl = lv_slider_create(row);
        lv_slider_set_range(sl, 0, 100);
        lv_slider_set_value(sl, (int)(osc[i].volume * 100.0f), LV_ANIM_OFF);
        lv_obj_set_width(sl, 110);
        lv_obj_add_event_cb(sl, osc_vol_cb, LV_EVENT_VALUE_CHANGED,
                            (void *)(uintptr_t)i);
    }

    tab_eff = lv_tabview_add_tab(tv, "Effets");
    lv_obj_set_flex_flow(tab_eff, LV_FLEX_FLOW_COLUMN);
    lv_obj_set_style_pad_row(tab_eff, 6, 0);
    Refresh_Effects_UI();
}

int main(void) {
    BOARD_InitHardware();
    DEMO_SetupTick();

    lv_init();
    lv_port_disp_init();
    lv_port_indev_init();
#if LV_USE_LOG
    lv_log_register_print_cb(print_cb);
#endif

    for (int i = 0; i < MAX_VOICES; i++) {
        voices[i].active = 0;
        voices[i].env_state = ENV_IDLE;
        voices[i].env_val = 0.0f;
        for (int o = 0; o < NUM_OSC; o++) voices[i].phase[o] = 0.0f;
    }

    for (int o = 0; o < NUM_OSC; o++) {
        osc[o].detune    = 0.0f;
        osc[o].volume    = (o == 0) ? 0.5f : 0.0f;
        osc[o].wave_mode = (uint8_t)o;
    }

    for (int i = 0; i < LUT_SIZE; i++)
        sinus_lut[i] = sinf((2.0f * M_PI * (float)i) / (float)LUT_SIZE);

    memset(reverb_buf, 0, sizeof(reverb_buf));
    memset(delay_buf,  0, sizeof(delay_buf));
    memset(chorus_buf, 0, sizeof(chorus_buf));

    CLOCK_EnableClock(kCLOCK_LPFlexComm3);
    CLOCK_SetClkDiv(kCLOCK_DivFlexcom3Clk, 1U);
    CLOCK_AttachClk(kFRO12M_to_FLEXCOMM3);

    lpuart_config_t uartCfg;
    LPUART_GetDefaultConfig(&uartCfg);
    uartCfg.baudRate_Bps = 31250U;
    uartCfg.enableRx = true;
    uartCfg.enableTx = false;
    LPUART_Init(MIDI_UART, &uartCfg, 12000000U);
    MIDI_UART->WATER = (MIDI_UART->WATER & ~LPUART_WATER_RXWATER_MASK) | LPUART_WATER_RXWATER(0);
    LPUART_DisableInterrupts(MIDI_UART, kLPUART_RxDataRegFullInterruptEnable);
    DisableIRQ(MIDI_IRQn);

    SAI_Init(DEMO_SAI_BASE);
    sai_transceiver_t config;
    SAI_GetClassicI2SConfig(&config, kSAI_WordWidth16bits, kSAI_Stereo, kSAI_Channel0Mask);
    config.masterSlave = kSAI_Master;
    config.bitClock.bclkSource = kSAI_BclkSourceBusclk;
    SAI_TxSetConfig(DEMO_SAI_BASE, &config);

    uint32_t actual_bus_clock = CLOCK_GetFreq(kCLOCK_BusClk);
    SAI_TxSetBitClockRate(DEMO_SAI_BASE, actual_bus_clock, SAMPLE_RATE, kSAI_WordWidth16bits, 2);

    SAI_TxEnable(DEMO_SAI_BASE, true);

    Create_Synth_UI();

    for (;;) {
        MIDI_Poll();
        Generate_Audio_Chunk(audio_buffer, BUFFER_SIZE);
        SAI_WriteBlocking(DEMO_SAI_BASE, 0, 16, (uint8_t*)audio_buffer, sizeof(audio_buffer));

        if (s_lvglPending) {
            s_lvglPending = false;
            lv_timer_handler();
        }
    }
}
