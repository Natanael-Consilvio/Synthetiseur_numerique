#include "board.h"
#include "pin_mux.h"
#include "clock_config.h"
#include "peripherals.h"
#include "fsl_lpuart.h"
#include "fsl_sai.h"
#include "fsl_debug_console.h"
#include <math.h>

#define DEMO_SAI_BASE SAI0
#define SAMPLE_RATE 48000
#define BUFFER_SIZE 32
#define AMPLITUDE 4000.0f
#define LUT_SIZE 256
#define MAX_VOICES 4

#ifndef M_PI
#define M_PI 3.14159265358979323846f
#endif

float sinus_lut[LUT_SIZE];

volatile float mix_sine = 1.0f;
volatile float mix_square = 0.0f;
volatile float mix_saw = 0.0f;

#define KNOB_1_CC 74
#define KNOB_2_CC 71
#define KNOB_3_CC 76

typedef struct {
    uint8_t active;
    uint8_t midi_note;
    float frequency;
    float phase;
} Voice;

Voice voices[MAX_VOICES];
uint8_t midi_status = 0;
uint8_t midi_note = 0;
uint8_t midi_velocity = 0;
uint8_t midi_index = 0;

void Note_On(uint8_t note) {
    PRINTF("NOTE RECUE : %d\r\n", note);
    for (int i = 0; i < MAX_VOICES; i++) {
        if (voices[i].active && voices[i].midi_note == note) return;
    }
    for (int i = 0; i < MAX_VOICES; i++) {
        if (!voices[i].active) {
            voices[i].midi_note = note;
            voices[i].frequency = 440.0f * powf(2.0f, ((float)note - 69.0f) / 12.0f);
            voices[i].phase = 0.0f;
            voices[i].active = 1;
            return;
        }
    }
    voices[0].midi_note = note;
    voices[0].frequency = 440.0f * powf(2.0f, ((float)note - 69.0f) / 12.0f);
    voices[0].phase = 0.0f;
    voices[0].active = 1;
}

void Note_Off(uint8_t note) {
    for (int i = 0; i < MAX_VOICES; i++) {
        if (voices[i].midi_note == note) {
            voices[i].active = 0;
        }
    }
}

void Process_MIDI_Byte(uint8_t byte) {
    if (byte >= 0xF8) return;

    if (byte & 0x80) {
        uint8_t cmd = byte & 0xF0;
        if (cmd == 0x90 || cmd == 0x80 || cmd == 0xB0) {
            midi_status = byte;
            midi_index = 0;
        } else {
            midi_status = 0;
        }
        return;
    }

    if (midi_status == 0) return;

    if (midi_index == 0) {
        midi_note = byte;
        midi_index = 1;
    } else if (midi_index == 1) {
        midi_velocity = byte;
        midi_index = 0;

        uint8_t cmd = midi_status & 0xF0;

        if (cmd == 0x90 && midi_velocity > 0) {
            Note_On(midi_note);
        }
        else if (cmd == 0x80 || (cmd == 0x90 && midi_velocity == 0)) {
            Note_Off(midi_note);
        }
        else if (cmd == 0xB0) {
            float knob_value = (float)midi_velocity / 127.0f;

            if (midi_note == KNOB_1_CC) {
                mix_sine = knob_value;
            } else if (midi_note == KNOB_2_CC) {
                mix_square = knob_value;
            } else if (midi_note == KNOB_3_CC) {
                mix_saw = knob_value;
            } else {
                PRINTF("CC: %d | Val: %d\r\n", midi_note, midi_velocity);
            }
        }
    }
}

void MIDI_Poll(void) {
    uint32_t flags = LPUART_GetStatusFlags(LP_FLEXCOMM3_PERIPHERAL);

    if (flags & (kLPUART_RxOverrunFlag | kLPUART_NoiseErrorFlag | kLPUART_FramingErrorFlag)) {
        LPUART_ClearStatusFlags(LP_FLEXCOMM3_PERIPHERAL, kLPUART_RxOverrunFlag | kLPUART_NoiseErrorFlag | kLPUART_FramingErrorFlag);
        LPUART_ReadByte(LP_FLEXCOMM3_PERIPHERAL);
        midi_status = 0;
        midi_index = 0;
    }

    while (LPUART_GetStatusFlags(LP_FLEXCOMM3_PERIPHERAL) & kLPUART_RxDataRegFullFlag) {
        uint8_t byte = LPUART_ReadByte(LP_FLEXCOMM3_PERIPHERAL);
        Process_MIDI_Byte(byte);
    }
}

void Generate_Audio_Chunk(uint32_t *buffer, uint32_t size) {
    float total_mix = mix_sine + mix_square + mix_saw;
    if (total_mix <= 0.001f) total_mix = 1.0f;

    for (uint32_t i = 0; i < size; i++) {
        float mixed_sample = 0.0f;

        for (int v = 0; v < MAX_VOICES; v++) {
            if (voices[v].active) {
                float osc_sine = 0.0f;
                float osc_square = 0.0f;
                float osc_saw = 0.0f;

                uint32_t index = (uint32_t)(voices[v].phase * (float)LUT_SIZE);
                if (index >= LUT_SIZE) index = 0;

                osc_sine = sinus_lut[index];
                osc_square = (voices[v].phase < 0.5f) ? 1.0f : -1.0f;
                osc_saw = (2.0f * voices[v].phase) - 1.0f;

                float combined_osc = (osc_sine * mix_sine) + (osc_square * mix_square) + (osc_saw * mix_saw);
                combined_osc /= total_mix;

                mixed_sample += combined_osc * AMPLITUDE;

                voices[v].phase += voices[v].frequency / (float)SAMPLE_RATE;
                if (voices[v].phase >= 1.0f) voices[v].phase -= 1.0f;
            }
        }

        int16_t sample_value = (int16_t)mixed_sample;
        buffer[i] = (uint32_t)((sample_value << 16) | (uint16_t)sample_value);
    }
}

int main(void) {
    BOARD_InitBootPins();
    BOARD_InitBootPeripherals();
    BOARD_BootClockPLL150M();
    BOARD_InitDebugConsole();

    for (int i = 0; i < MAX_VOICES; i++) {
        voices[i].active = 0;
        voices[i].phase = 0.0f;
    }

    for (int i = 0; i < LUT_SIZE; i++) {
        sinus_lut[i] = sinf((2.0f * M_PI * (float)i) / (float)LUT_SIZE);
    }

    SAI_Init(DEMO_SAI_BASE);
    sai_transceiver_t config;
    SAI_GetClassicI2SConfig(&config, kSAI_WordWidth16bits, kSAI_Stereo, kSAI_Channel0Mask);
    config.masterSlave = kSAI_Master;
    config.bitClock.bclkSource = kSAI_BclkSourceBusclk;
    SAI_TxSetConfig(DEMO_SAI_BASE, &config);

    uint32_t actual_bus_clock = CLOCK_GetFreq(kCLOCK_BusClk);
    SAI_TxSetBitClockRate(DEMO_SAI_BASE, actual_bus_clock, SAMPLE_RATE, kSAI_WordWidth16bits, 2);

    LP_FLEXCOMM3_PERIPHERAL->WATER = (LP_FLEXCOMM3_PERIPHERAL->WATER & ~LPUART_WATER_RXWATER_MASK) | LPUART_WATER_RXWATER(0);

    LPUART_DisableInterrupts(LP_FLEXCOMM3_PERIPHERAL, kLPUART_RxDataRegFullInterruptEnable);
    DisableIRQ(LP_FLEXCOMM3_IRQn);

    uint32_t audio_buffer[BUFFER_SIZE];
    SAI_TxEnable(DEMO_SAI_BASE, true);

    while (1) {
        MIDI_Poll();
        Generate_Audio_Chunk(audio_buffer, BUFFER_SIZE);
        SAI_WriteBlocking(DEMO_SAI_BASE, 0, 16, (uint8_t*)audio_buffer, sizeof(audio_buffer));
    }
}
